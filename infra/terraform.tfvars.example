# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit it.

# Azure region — leave as-is unless you want a different location
# location = "northeurope"

# If "worktasksregistry" is already taken by someone else, change this
# acr_name = "worktasksregistry"

# Generate with: openssl rand -base64 32
nextauth_secret = ""

# MongoDB Atlas connection string (from Atlas dashboard → Connect)
mongodb_uri = "mongodb+srv://user:pass@cluster.mongodb.net"

# The name of your database inside Atlas
mongodb_db_name = "worktasks"

# Gmail SMTP (use an App Password, not your real Gmail password)
# Enable 2FA on your Google account, then generate an App Password at:
# https://myaccount.google.com/apppasswords
smtp_host  = "smtp.gmail.com"
smtp_port  = "587"
smtp_user  = "you@gmail.com"
smtp_pass  = ""
email_from = "Worktasks <you@gmail.com>"
